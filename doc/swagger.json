{
  "swagger": "2.0",
  "info": {
    "title": "Library Backend API",
    "version": "1.0.0",
    "description": "API para gerenciamento de usuários, coleções e livros favoritos com autenticação JWT"
  },
  "host": "127.0.0.1:5000",
  "basePath": "/",
  "schemes": ["http"],

  "tags": [
    {
      "name": "Auth",
      "description": "Autenticação de usuários"
    },
    {
      "name": "Coleções",
      "description": "Gerenciamento de coleções"
    },
    {
      "name": "Favoritos",
      "description": "Gerenciamento de livros favoritos"
    }
  ],

  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Digite: Bearer {seu_token}"
    }
  },

  "definitions": {
    "Usuario": {
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "senha": { "type": "string" }
      }
    },
    "Login": {
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "senha": { "type": "string" }
      }
    },
    "Livro": {
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "ano": { "type": "integer" },
        "descricao": { "type": "string" },
        "autor": { "type": "string" },
        "capa": { "type": "string" }
      }
    }
  },

  "paths": {

    "/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Autenticar usuário",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Login" }
          }
        ],
        "responses": {
        
            "200": {
            "description": "Login realizado",
            "schema": {
                "type": "object",
                "properties": {
                "status": { "type": "string" },
                "usuario_id": { "type": "integer" },
                "nome": { "type": "string" },
                "autorizacao": { "type": "string" }
                }
            },
            "examples": {
                "application/json": {
                "status": "ok",
                "usuario_id": 1,
                "nome": "Alice",
                "autorizacao": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                }
            }
            },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },

    "/cadastro": {
      "post": {
        "tags": ["Auth"],
        "summary": "Cadastrar usuário",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Usuario" }
          }
        ],
        "responses": {
          "201": { "description": "Usuário criado" },
          "400": { "description": "Erro de validação" }
        }
      }
    },

    "/colections": {
      "get": {
        "tags": ["Coleções"],
        "summary": "Listar coleções do usuário",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de coleções" },
          "401": { "description": "Não autorizado" }
        }
      }
    },

    "/nova_colecao": {
      "post": {
        "tags": ["Coleções"],
        "summary": "Criar nova coleção",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "nome": { "type": "string" }
              }
            }
          }
        ],
        "responses": {
          "201": { "description": "Coleção criada" }
        }
      }
    },

    "/add_favoritos/{colection_id}": {
      "post": {
        "tags": ["Favoritos"],
        "summary": "Adicionar livro aos favoritos",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "colection_id",
            "in": "path",
            "required": true,
            "type": "integer"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Livro" }
          }
        ],
        "responses": {
          "201": { "description": "Livro adicionado" },
          "403": { "description": "Não autorizado" },
          "404": { "description": "Coleção não encontrada" }
        }
      }
    },

    "/delete_colecao/{colection_id}": {
      "delete": {
        "tags": ["Coleções"],
        "summary": "Remover coleção",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "colection_id",
            "in": "path",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": { "description": "Coleção removida" },
          "404": { "description": "Não encontrada" }
        }
      }
    }
  }
}